# ---- Địa chỉ truy cập công khai (đổi IP/cổng ở ĐÂY là đủ) ----
#   PUBLIC_HOST: IP hoặc hostname máy chủ mà trình duyệt người dùng truy cập.
#   GATEWAY_PORT: cổng host của gateway (Caddy). Mọi URL hướng trình duyệt
#   (issuer Keycloak, callback oauth2, link trên dashboard) đều dựng từ 2 biến này.
PUBLIC_HOST=192.168.6.18
GATEWAY_PORT=8090

# ---- PostgreSQL ----
PG_USER=mlops
PG_PASSWORD=mlops_pw

# ---- MinIO (S3 storage) ----
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# ---- CVAT admin ----
CVAT_ADMIN_USER=admin
CVAT_ADMIN_PASSWORD=admin_pw

# ---- Keycloak (SSO) ----
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin_pw
OAUTH2_PROXY_SECRET=oauth2-proxy-secret-CHANGE-ME
# Tạo cookie secret 32 ký tự: openssl rand -hex 16
COOKIE_SECRET=0123456789abcdef0123456789abcdef

# Đổi toàn bộ mật khẩu trước khi dùng production.
